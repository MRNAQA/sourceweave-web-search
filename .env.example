# Optional overrides for the repo-local Docker Compose stack.
# Copy this file to .env before changing values.

SEARXNG_IMAGE=searxng/searxng:2026.4.11-9e08a6771
SEARXNG_SECRET=sourceweave-local-searxng-secret-change-before-exposing

CRAWL4AI_IMAGE=unclecode/crawl4ai:0.8.6
CRAWL4AI_API_TOKEN=sourceweave-local-crawl4ai-token-change-before-exposing

SOURCEWEAVE_SEARCH_SEARXNG_BASE_URL=http://searxng:8080/search?format=json&q=<query>
SOURCEWEAVE_SEARCH_CRAWL4AI_BASE_URL=http://crawl4ai:11235
SOURCEWEAVE_SEARCH_CACHE_REDIS_URL=redis://redis:6379/2
